generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(schema: "public")]
}

enum MembershipRole {
  OWNER
  ADMIN
  CONTRIBUTOR
  REVIEWER
  VIEWER
}

enum MarketCode {
  US
  EU
  UK
  VN
  CA
  AU
  OTHER
}

enum ClassificationStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum VaultTag {
  LAB_TEST
  INVOICE
  PHOTO
  SPEC
  OTHER
}

enum RiskType {
  AD
  CVD
  PERMIT
  TARIFF
  OTHER
}

model Organization {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  timezone        String?          @default("UTC")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     Membership[]
  products        Product[]
  classifications Classification[]
  referenceFiles  VaultFile[]
  auditLogs       AuditLog[]
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  fullName        String?
  authProviderId  String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     Membership[]
  products        Product[]        @relation("ProductCreators")
  classifications Classification[] @relation("ClassificationReviewers")
  dossiers        Dossier[]
  auditLogs       AuditLog[]
  uploads         VaultFile[]      @relation("VaultUploader")
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole @default(CONTRIBUTOR)
  userId         String
  organizationId String
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model Product {
  id              String            @id @default(cuid())
  organizationId  String
  createdById     String
  name            String
  description     String
  intendedUse     String?
  targetMarkets   MarketCode[]
  status          String            @default("draft")
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id])
  creator         User              @relation("ProductCreators", fields: [createdById], references: [id])
  materials       ProductMaterial[]
  referenceFiles  VaultFile[]
  classifications Classification[]

  @@index([organizationId])
  @@index([createdById])
}

model ProductMaterial {
  id         String  @id @default(cuid())
  productId  String
  material   String
  percentage Decimal @db.Decimal(5, 2)
  product    Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model VaultFile {
  id             String       @id @default(cuid())
  organizationId String
  productId      String?
  uploadedById   String?
  tag            VaultTag
  label          String
  storagePath    String
  contentType    String
  sizeBytes      Int
  sha256         String
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  product        Product?     @relation(fields: [productId], references: [id])
  uploadedBy     User?        @relation("VaultUploader", fields: [uploadedById], references: [id])

  @@index([organizationId])
  @@index([productId])
}

model Classification {
  id             String                 @id @default(cuid())
  organizationId String
  productId      String
  reviewerId     String?
  market         MarketCode
  htsCode        String?
  status         ClassificationStatus   @default(DRAFT)
  confidence     Decimal?               @db.Decimal(5, 2)
  summary        String?
  reasoningTrail Json?
  exclusionNotes Json?
  humanNotes     String?
  requiresReview Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id])
  product        Product                @relation(fields: [productId], references: [id])
  reviewer       User?                  @relation("ClassificationReviewers", fields: [reviewerId], references: [id])
  dossier        Dossier?
  dutySummary    DutySummary?
  riskFlags      RiskFlag[]
  sources        ClassificationSource[]

  @@index([organizationId, market])
  @@index([productId, market])
}

model ClassificationSource {
  id               String         @id @default(cuid())
  classificationId String
  sourceType       String
  referenceId      String?
  excerpt          String
  metadata         Json?
  classification   Classification @relation(fields: [classificationId], references: [id])

  @@index([classificationId])
}

model Dossier {
  id               String         @id @default(cuid())
  classificationId String         @unique
  generatedById    String?
  storagePath      String
  sha256           String
  generatedAt      DateTime       @default(now())
  classification   Classification @relation(fields: [classificationId], references: [id])
  generatedBy      User?          @relation(fields: [generatedById], references: [id])
}

model DutySummary {
  id               String         @id @default(cuid())
  classificationId String         @unique
  baseValue        Decimal        @db.Decimal(18, 4)
  dutyRate         Decimal        @db.Decimal(7, 4)
  vatRate          Decimal?       @db.Decimal(7, 4)
  mpfRate          Decimal?       @db.Decimal(7, 4)
  section301Rate   Decimal?       @db.Decimal(7, 4)
  estimatedDuty    Decimal        @db.Decimal(18, 4)
  estimatedTaxes   Decimal?       @db.Decimal(18, 4)
  classification   Classification @relation(fields: [classificationId], references: [id])
}

model RiskFlag {
  id               String         @id @default(cuid())
  classificationId String
  riskType         RiskType
  label            String
  details          String?
  classification   Classification @relation(fields: [classificationId], references: [id])

  @@index([classificationId])
}

model LegalNote {
  id        String                 @id @default(cuid())
  chapter   Int
  heading   Int?
  noteKey   String?
  content   String
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([chapter, heading])
}

model BindingRuling {
  id        String                 @id @default(cuid())
  market    MarketCode
  reference String                 @unique
  title     String
  body      String
  htsCode   String
  embedding Unsupported("vector")?
  issuedAt  DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([market, htsCode])
}

model DutyRate {
  id        String     @id @default(cuid())
  market    MarketCode
  htsCode   String
  dutyRate  Decimal    @db.Decimal(7, 4)
  vatRate   Decimal?   @db.Decimal(7, 4)
  notes     String?
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())

  @@index([market, htsCode])
}

model Section301Measure {
  id        String    @id @default(cuid())
  htsCode   String
  listName  String
  rate      Decimal   @db.Decimal(7, 4)
  effective DateTime
  expires   DateTime?
  createdAt DateTime  @default(now())

  @@unique([htsCode, listName])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  entityType     String
  entityId       String
  action         String
  payload        Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
}
