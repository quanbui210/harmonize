generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  CONTRIBUTOR
  REVIEWER
  VIEWER
}

enum MarketCode {
  US
  EU
  UK
  VN
  CA
  AU
  OTHER
}

enum ClassificationStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum VaultTag {
  LAB_TEST
  INVOICE
  PHOTO
  SPEC
  OTHER
}

enum RiskType {
  AD
  CVD
  PERMIT
  TARIFF
  OTHER
}

enum ShipmentType {
  IMPORT
  EXPORT
}

enum ShipmentStatus {
  DRAFT
  IN_TRANSIT
  CLEARED
  AUDITED
  DISPUTED
  CANCELLED
}

model Organization {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  timezone        String?          @default("UTC")
  logoUrl         String?          // URL to organization logo/avatar
  createdById     String?          // Track who created the org (first OWNER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     Membership[]
  products        Product[]
  classifications Classification[]
  referenceFiles  VaultFile[]
  auditLogs       AuditLog[]
  chatSessions    ChatSession[]
  shipments       Shipment[]
  invitations     OrganizationInvitation[]
  createdBy       User?            @relation("OrganizationCreator", fields: [createdById], references: [id])
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  fullName        String?
  authProviderId  String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     Membership[]
  products        Product[]        @relation("ProductCreators")
  classifications Classification[] @relation("ClassificationReviewers")
  dossiers        Dossier[]
  auditLogs       AuditLog[]
  uploads         VaultFile[]      @relation("VaultUploader")
  chatSessions    ChatSession[]    @relation("ChatSessions")
  createdOrganizations Organization[] @relation("OrganizationCreator")
  sentInvitations OrganizationInvitation[]
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole @default(CONTRIBUTOR)
  userId         String
  organizationId String
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model OrganizationInvitation {
  id             String         @id @default(cuid())
  organizationId String
  email          String
  role           MembershipRole @default(CONTRIBUTOR)
  invitedById    String         // Admin/Owner who sent invitation
  token          String         @unique // Secure token for acceptance
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime       @default(now())
  
  organization   Organization   @relation(fields: [organizationId], references: [id])
  invitedBy      User           @relation(fields: [invitedById], references: [id])
  
  @@unique([organizationId, email]) // One pending invitation per email per org
  @@index([token])
  @@index([email])
}

model Product {
  id              String            @id @default(cuid())
  organizationId  String
  createdById     String
  name            String
  description     String
  intendedUse     String?
  targetMarkets   MarketCode[]
  status          String            @default("draft")
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id])
  creator         User              @relation("ProductCreators", fields: [createdById], references: [id])
  materials       ProductMaterial[]
  referenceFiles  VaultFile[]
  classifications Classification[]
  shipmentItems   ShipmentItem[]

  @@index([organizationId])
  @@index([createdById])
}

model ProductMaterial {
  id         String  @id @default(cuid())
  productId  String
  material   String
  percentage Decimal @db.Decimal(5, 2)
  product    Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model VaultFile {
  id             String       @id @default(cuid())
  organizationId String
  productId      String?
  uploadedById   String?
  tag            VaultTag
  label          String
  storagePath    String
  contentType    String
  sizeBytes      Int
  sha256         String
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  product        Product?     @relation(fields: [productId], references: [id])
  uploadedBy     User?        @relation("VaultUploader", fields: [uploadedById], references: [id])

  @@index([organizationId])
  @@index([productId])
}

model Classification {
  id                String                 @id @default(cuid())
  organizationId    String
  productId        String
  reviewerId        String?
  market            MarketCode
  hsCode            String?                // HS Code (6 digits) - base international code
  htsCode           String?                // HTS Code (10 digits) - US extension
  status            ClassificationStatus   @default(DRAFT)
  confidence        Decimal?               @db.Decimal(5, 2)
  summary           String?
  reasoningTrail    Json?
  exclusionNotes    Json?
  humanNotes        String?
  requiresReview    Boolean                @default(false)
  refinementQuestion String?              // AI refinement question
  refinementAnswer   String?              // User's answer to refinement question
  legalRationale    String?              // AI-generated legal rationale
  distinctions      Json?                 // Array of {heading, reason} distinctions
  keyFeatures       Json?                 // Array of key product features
  griRule           String?               // GRI rule applied
  notes             String?               // Additional classification notes
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  organization      Organization           @relation(fields: [organizationId], references: [id])
  product           Product                @relation(fields: [productId], references: [id])
  reviewer          User?                  @relation("ClassificationReviewers", fields: [reviewerId], references: [id])
  dossier           Dossier?
  dutySummary       DutySummary?
  riskFlags         RiskFlag[]
  sources           ClassificationSource[]
  shipmentItems     ShipmentItem[]

  @@index([organizationId, market])
  @@index([productId, market])
}

model ClassificationSource {
  id               String         @id @default(cuid())
  classificationId String
  sourceType       String
  referenceId      String?
  excerpt          String
  metadata         Json?
  classification   Classification @relation(fields: [classificationId], references: [id])

  @@index([classificationId])
}

model Dossier {
  id               String         @id @default(cuid())
  classificationId String         @unique
  generatedById    String?
  storagePath      String
  sha256           String
  generatedAt      DateTime       @default(now())
  classification   Classification @relation(fields: [classificationId], references: [id])
  generatedBy      User?          @relation(fields: [generatedById], references: [id])
}

model DutySummary {
  id               String         @id @default(cuid())
  classificationId String         @unique
  baseValue        Decimal        @db.Decimal(18, 4)
  dutyRate         Decimal        @db.Decimal(7, 4)
  vatRate          Decimal?       @db.Decimal(7, 4)
  mpfRate          Decimal?       @db.Decimal(7, 4)
  section301Rate   Decimal?       @db.Decimal(7, 4)
  estimatedDuty    Decimal        @db.Decimal(18, 4)
  estimatedTaxes   Decimal?       @db.Decimal(18, 4)
  classification   Classification @relation(fields: [classificationId], references: [id])
}

model RiskFlag {
  id               String         @id @default(cuid())
  classificationId String
  riskType         RiskType
  label            String
  details          String?
  classification   Classification @relation(fields: [classificationId], references: [id])

  @@index([classificationId])
}

model LegalNote {
  id        String                 @id @default(cuid())
  chapter   Int
  heading   Int?
  noteKey   String?
  content   String
  market    MarketCode
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([chapter, heading, market])
}

model LegalSourceChunk {
  id          String                  @id @default(cuid())
  source      String
  regulation  String
  language    String                  @default("EN")
  sectionPath String
  content     String
  sha256      String                  @unique
  pageStart   Int?
  pageEnd     Int?
  embedding   Unsupported("vector")?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([regulation, language])
  @@index([source])
}

model CnCodeDescription {
  id          String     @id @default(cuid())
  cnCode      String     @unique
  market      MarketCode
  description String
  fullText    String?    // Full description text
  notes       String?    // Additional notes
  source      String     @default("TARIC") // TARIC, EUR_LEX, MANUAL
  fetchedAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdAt   DateTime   @default(now())

  @@index([cnCode, market])
  @@index([market])
}

model BindingRuling {
  id        String                 @id @default(cuid())
  market    MarketCode
  reference String                 @unique
  title     String
  body      String
  htsCode   String
  embedding Unsupported("vector")?
  issuedAt  DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([market, htsCode])
}

model DutyRate {
  id        String     @id @default(cuid())
  market    MarketCode
  htsCode   String
  dutyRate  Decimal    @db.Decimal(7, 4)
  vatRate   Decimal?   @db.Decimal(7, 4)
  notes     String?
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())

  @@index([market, htsCode])
}

model Section301Measure {
  id        String    @id @default(cuid())
  htsCode   String
  listName  String
  rate      Decimal   @db.Decimal(7, 4)
  effective DateTime
  expires   DateTime?
  createdAt DateTime  @default(now())

  @@unique([htsCode, listName])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  entityType     String
  entityId       String
  action         String
  payload        Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
}

model ChatSession {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  title          String?      // Optional title (e.g., "CN Code Questions")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation("ChatSessions", fields: [userId], references: [id])
  messages       ChatMessage[]

  @@index([organizationId, userId])
  @@index([userId])
}

model ChatMessage {
  id            String       @id @default(cuid())
  sessionId     String
  role          String       // "user" | "assistant"
  content       String
  sources       Json?        // Array of source citations
  createdAt     DateTime     @default(now())
  session       ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model Shipment {
  id                      String            @id @default(cuid())
  organizationId          String
  shipmentNumber          String            // User-provided reference
  type                    ShipmentType
  status                  ShipmentStatus    @default(DRAFT)
  originCountry            String?
  destinationCountry      String?
  shippingDate            DateTime?
  arrivalDate             DateTime?
  customsDeclarationNumber String?
  invoiceValue            Decimal?          @db.Decimal(12, 2)
  totalDuty               Decimal?          @db.Decimal(12, 2)
  incoterms               String?
  carrier                 String?
  freightForwarder        String?
  notes                   String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  
  organization            Organization      @relation(fields: [organizationId], references: [id])
  items                   ShipmentItem[]
  documents               ShipmentDocument[]
  
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([shipmentNumber])
}

model ShipmentItem {
  id                String          @id @default(cuid())
  shipmentId        String
  productId         String
  classificationId  String?
  quantity          Decimal         @db.Decimal(10, 2)
  unitValue         Decimal         @db.Decimal(12, 2)
  cnCode            String?
  hsCode            String?
  htsCode           String?
  dutyRate          Decimal?        @db.Decimal(5, 2)
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  shipment          Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product           Product        @relation(fields: [productId], references: [id])
  classification    Classification? @relation(fields: [classificationId], references: [id])
  
  @@index([shipmentId])
  @@index([productId])
  @@index([classificationId])
}

model ShipmentDocument {
  id            String   @id @default(cuid())
  shipmentId    String
  documentType  String   // CUSTOMS_DECLARATION, INVOICE, CERTIFICATE, CLEARANCE, etc.
  fileName      String
  storagePath   String   // Path in Supabase storage
  uploadedAt    DateTime @default(now())
  
  shipment      Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  
  @@index([shipmentId])
}
