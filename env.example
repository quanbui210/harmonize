# Connect to Supabase via connection pooling (for application use)
# You can use either port 5432 or 6543 - both work with the pooler
# Port 5432: Transaction mode (better for migrations)
# Port 6543: Session mode (better for regular queries)
DATABASE_URL="postgresql://postgres.svjfqntqnilhdjmsshrq:PASSWORD@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# For migrations - use the SAME pooler URL as DATABASE_URL (same port)
# IMPORTANT: Both should point to pooler, not direct connection
DIRECT_URL="postgresql://postgres.svjfqntqnilhdjmsshrq:PASSWORD@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI Configuration (for EU Classification & Reasoning Dossier)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Langfuse Configuration (LLM Observability & Tracing)
# Optional: Set these to enable LLM call tracing and monitoring
# Get your keys from https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# TARIC API Configuration (EU Customs Data)
# ✅ NEW (2025): Official EU TARIC API - NO API KEY REQUIRED!
# Provider options: "SOAP" (official, free, no API key), "REST" (third-party, paid), "MOCK" (development)
TARIC_PROVIDER="SOAP"
# Official EU TARIC API WSDL (public, no registration needed)
TARIC_WSDL_URL="https://ec.europa.eu/taxation_customs/dds2/taric/services/goods?wsdl"
# For REST (third-party aggregators like Taric Support, TariffApi): Requires API key
# TARIC_API_KEY=""
# TARIC_REST_API_URL="https://api.taricsupport.com/v1"

# VIES (VAT Validation) - Public SOAP service, no key required
VIES_WSDL_URL="http://ec.europa.eu/taxation_customs/vies/services/checkVatService?wsdl"

# EORI (Economic Operator ID) - Requires registration with national customs authority
EORI_API_KEY=""
EORI_BASE_URL="https://ec.europa.eu/taxation_customs/dds2/eos"
